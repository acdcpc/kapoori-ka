rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ===========================
    // USERS
    // ===========================
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ===========================
    // CHILDREN
    // ===========================
    match /children/{childId} {
      allow get: if signedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow list: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.ownerId == request.auth.uid;
      allow delete: if signedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ===========================
    // GROWTH RECORDS
    // ===========================
    match /growth_records/{recordId} {
      allow get: if signedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow list: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.ownerId == request.auth.uid;
      allow delete: if signedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ===========================
    // VACCINE RECORDS
    // ===========================
    match /vaccinations/{recordId} {
      allow get: if signedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow list: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.ownerId == request.auth.uid;
      allow delete: if signedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ===========================
    // MILESTONE RECORDS — list allowed for any signed-in user
    // since the app filters by childId client-side
    // ===========================
    match /milestones/{recordId} {
      allow get: if signedIn()
        && get(/databases/$(database)/documents/children/$(resource.data.childId)).data.ownerId == request.auth.uid;
      allow list: if signedIn();
      allow create: if signedIn()
        && get(/databases/$(database)/documents/children/$(request.resource.data.childId)).data.ownerId == request.auth.uid;
      allow update: if signedIn()
        && get(/databases/$(database)/documents/children/$(resource.data.childId)).data.ownerId == request.auth.uid;
      allow delete: if signedIn()
        && get(/databases/$(database)/documents/children/$(resource.data.childId)).data.ownerId == request.auth.uid;
    }

    // ===========================
    // MCHAT
    // ===========================
    match /mchat_responses/{responseId} {
      allow get: if signedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow list: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.ownerId == request.auth.uid;
      allow delete: if signedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ===========================
    // SUBSCRIPTIONS
    // ===========================
    match /subscriptions/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ===========================
    // PAYMENTS
    // ===========================
    match /payments/{paymentId} {
      allow get: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
