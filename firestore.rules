rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Admin check via Firebase Auth custom claim (not Firestore field)
    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    // ===========================
    // USERS
    // Users can create & read their own doc.
    // Cannot update/delete — Cloud Functions (Admin SDK) handles premium/isAdmin.
    // ===========================
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update, delete: if isAdmin();
    }

    // ===========================
    // CHILDREN
    // ===========================
    match /children/{childId} {
      allow get: if signedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow list: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if signedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ===========================
    // GROWTH RECORDS
    // ===========================
    match /growth_records/{recordId} {
      allow get: if signedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow list: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if signedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ===========================
    // VACCINE RECORDS (vaccinations)
    // ===========================
    match /vaccinations/{recordId} {
      allow get: if signedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow list: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if signedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ===========================
    // MILESTONE RECORDS
    // ===========================
    match /milestones/{recordId} {
      allow get: if signedIn() && (
        get(/databases/$(database)/documents/children/$(resource.data.childId)).data.ownerId == request.auth.uid
        || isAdmin()
      );
      allow list: if signedIn();
      allow create: if signedIn() && (
        get(/databases/$(database)/documents/children/$(request.resource.data.childId)).data.ownerId == request.auth.uid
      );
      allow update: if signedIn() && (
        get(/databases/$(database)/documents/children/$(resource.data.childId)).data.ownerId == request.auth.uid
      );
      allow delete: if signedIn() && (
        get(/databases/$(database)/documents/children/$(resource.data.childId)).data.ownerId == request.auth.uid
      );
    }

    // ===========================
    // MCHAT RESPONSES
    // ===========================
    match /mchat_responses/{responseId} {
      allow get: if signedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow list: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if signedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ===========================
    // SUBSCRIPTIONS
    // Users can create their own initial free subscription.
    // CRITICAL: Users CANNOT self-upgrade. Only Cloud Functions (Admin SDK) can.
    // ===========================
    match /subscriptions/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.status == 'free';
      allow update, delete: if isAdmin();
    }

    // ===========================
    // PAYMENTS
    // Users can create their own payment record (status forced to 'pending').
    // Users cannot update/delete after creation.
    // Admin can read/update/delete.
    // ===========================
    match /payments/{paymentId} {
      allow get: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.verifiedAt == null
        && request.resource.data.verifiedBy == null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ===========================
    // ACTIVATION CODES
    // Read by users (to verify code exists), managed by admin
    // ===========================
    match /activation_codes/{code} {
      allow get: if signedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
