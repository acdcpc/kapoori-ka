{
  "cli": {
    "version": ">=20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "prebuildCommand": "npx expo prebuild --clean --platform android"
    },
    "production": {
      "autoIncrement": true
    }
  }
}
